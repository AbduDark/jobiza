# Database configuration
DB_HOST=postgres
DB_NAME=user_db
DB_USER=myuser
DB_PASSWORD=mypassword
DB_PORT=5432

# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional JWT settings (for authentication)
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256